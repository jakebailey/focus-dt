{
  "name": "focus-dt",
  "version": "1.0.4",
  "description": "A simple command-line tool for running down PRs on DefinitelyTyped",
  "bin": {
    "focus-dt": "bin/focus-dt"
  },
  "type": "module",
  "scripts": {
    "prebuild": "npx gql-tada turbo",
    "build": "tsc -b .",
    "clean": "tsc -b --clean .",
    "start": "npm run build && node --enable-source-maps bin/focus-dt"
  },
  "author": "Ron Buckton <ron.buckton@microsoft.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DefinitelyTyped/focus-dt.git"
  },
  "bugs": {
    "url": "https://github.com/DefinitelyTyped/focus-dt/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.17.3",
    "@types/node": "^26.1.0",
    "@types/winreg": "^1.2.36",
    "@types/yargs": "^17.0.35",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "color-convert": "^3.1.3",
    "gql.tada": "^1.11.2",
    "iterable-query": "^1.0.0-pre.16",
    "octokit": "^5.0.5",
    "strip-ansi": "^7.2.0",
    "timeago.js": "^4.0.2",
    "vscode-chrome-debug-core": "^6.8.11",
    "winreg": "^1.2.5",
    "yargs": "^18.0.0"
  },
  "overrides": {
    "@mapbox/node-pre-gyp": "2.0.3"
  }
}
